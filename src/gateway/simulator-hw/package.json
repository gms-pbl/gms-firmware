		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tabler/icons-svelte": "^3.41.1",
		"@tailwindcss/vite": "^4.2.2",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"shadcn-svelte": "^1.2.7",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
