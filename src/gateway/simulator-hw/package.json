{
	"name": "simulator-hw",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"start": "HOST=${HOST:-0.0.0.0} PORT=${PORT:-4173} bun build/index.js",
		"preview": "vite preview",
		"prepare": "playwright install && svelte-kit sync || echo ''",
